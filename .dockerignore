# Игнорируем конфигурационные файлы
.env
.env.*
!.env.example
*.sh

# Игнорируем системные файлы
.git
.gitignore
.github
.dockerignore
/build/
/nginx/

# Игнорируем проектные файлы
mlops/
experiments/

# Игнорируем временные файлы IDE
.idea
.vscode
*.swp
*~

# Игнорируем кэш Python
__pycache__/
*.py[cod]
*.so
.python-version

# Игнорируем виртуальные окружения
venv/
.venv/
env/
ENV/

# Логи и артефакты покрытия/сборки
*.log
coverage.xml
dist/
*.egg-info/

# Тесты и документация (в рантайм-образ не нужны)
tests/
docs/
*.md
!README.md

# Кэши инструментов и планы
.pytest_cache/
.ruff_cache/
.mypy_cache/
.kimi-plans/
.pre-commit-config.yaml
